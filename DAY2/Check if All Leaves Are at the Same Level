
class Node:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None

def check_same_level(root) -> int:
    if not root:
        return 1
        
    queue = [root]
    
    while queue:
        level_size = len(queue)
        is_leaf_in_this_level = False
        
        for _ in range(level_size):
            curr = queue.pop(0)
            
            if not curr.left and not curr.right:
                is_leaf_in_this_level = True
                
            if curr.left:
                queue.append(curr.left)
            if curr.right:
                queue.append(curr.right)
                
        if is_leaf_in_this_level:
            if queue: 
                return 0
                
    return 1

root1 = Node(1)
root1.left = Node(2)
root1.right = Node(3)
print(check_same_level(root1))

root2 = Node(10)
root2.left = Node(20)
root2.right = Node(30)
root2.left.left = Node(10)
root2.left.right = Node(15)
print(check_same_level(root2))
