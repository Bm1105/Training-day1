class Node:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None

class BinaryTreeToDLL:
    def __init__(self):
        self.head = None
        self.prev = None

    def convert(self, root):
        if not root:
            return None

        self.convert(root.left)

        if not self.prev:
            self.head = root
        else:
            root.left = self.prev
            self.prev.right = root

        self.prev = root

        self.convert(root.right)
        return self.head

def print_list_forward(head):
    curr = head
    while curr:
        print(curr.data, end=" ")
        if not curr.right:
            break
        curr = curr.right
    print()
    return curr

def print_list_backward(tail):
    curr = tail
    while curr:
        print(curr.data, end=" ")
        curr = curr.left
    print()

root1 = Node(1)
root1.left = Node(3)
root1.right = Node(2)

converter1 = BinaryTreeToDLL()
head1 = converter1.convert(root1)
tail1 = print_list_forward(head1)
print_list_backward(tail1)

