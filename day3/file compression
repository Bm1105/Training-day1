import heapq
import os
import pickle

class HuffmanNode:
    def __init__(self, char, freq):
        self.char = char
        self.freq = freq
        self.left = None
        self.right = None

    # Define validators for the priority queue (Min-Heap) comparison
    def __lt__(self, other):
        return self.freq < other.freq

class FileZipper:
    def __init__(self):
        self.codes = {}
        self.reverse_codes = {}

    def _make_frequency_map(self, text_bytes):
        """Counts occurrence of each byte."""
        frequency = {}
        for byte in text_bytes:
            frequency[byte] = frequency.get(byte, 0) + 1
        return frequency

    def _build_huffman_tree(self, frequency):
        """Builds the Min-Heap tree structure."""
        heap = []
        for key in frequency:
            node = HuffmanNode(key, frequency[key])
            heapq.heappush(heap, node)

        while len(heap) > 1:
            node1 = heapq.heappop(heap)
            node2 = heapq.heappop(heap)

            merged = HuffmanNode(None, node1.freq + node2.freq)
            merged.left = node1
            merged.right = node2

            heapq.heappush(heap, merged)
        return heapq.heappop(heap)

    def _make_codes_helper(self, root, current_code):
        """Recursively generates bit string representations."""
        if root is None:
            return

        if root.char is not None:
            self.codes[root.char] = current_code
            self.reverse_codes[current_code] = root.char
            return

        self._make_codes_helper(root.left, current_code + "0")
        self._make_codes_helper(root.right, current_code + "1")

    def _make_codes(self, root):
        """Initializes code generation."""
        self.codes = {}
        self.reverse_codes = {}
        self._make_codes_helper(root, "")

    def _get_encoded_bitstring(self, text_bytes):
        """Replaces bytes with their Huffman bit strings."""
        return "".join(self.codes[byte] for byte in text_bytes)

    def _pad_encoded_text(self, encoded_text):
        """Pads the bitstream to make its length a multiple of 8."""
        extra_padding = 8 - (len(encoded_text) % 8)
        for _ in range(extra_padding):
            encoded_text += "0"

        # Store padding info in an 8-bit binary format
        padded_info = "{0:08b}".format(extra_padding)
        return padded_info + encoded_text

    def _get_byte_array(self, padded_encoded_text):
        """Converts strings of '0' and '1' into an actual bytearray."""
        b = bytearray()
        for i in range(0, len(padded_encoded_text), 8):
            byte = padded_encoded_text[i:i+8]
            b.append(int(byte, 2))
        return b

    def compress(self, input_path, output_path):
        """Compresses the input file into a custom zipped binary file."""
        if not os.path.exists(input_path):
            print(f"Error: File {input_path} not found.")
            return

        with open(input_path, 'rb') as f:
            file_data = f.read()

        if not file_data:
            print("Error: Input file is empty.")
            return

        # 1. Map frequencies & build tree
        frequency = self._make_frequency_map(file_data)
        root = self._build_huffman_tree(frequency)
        self._make_codes(root)

        # 2. Translate data to bitstream
        encoded_text = self._get_encoded_bitstring(file_data)
        padded_encoded_text = self._pad_encoded_text(encoded_text)
        compressed_bytes = self._get_byte_array(padded_encoded_text)

        # 3. Write metadata (the tree structure map) and bitstream to disk
        with open(output_path, 'wb') as output_file:
            # Pickle serialized frequency map acts as our file header structure
            pickle.dump(frequency, output_file)
            output_file.write(compressed_bytes)
            
        print(f"Compression successful! Saved to {output_path}")

    def decompress(self, input_path, output_path):
        """Decompresses the custom zipped binary file back to original data."""
        if not os.path.exists(input_path):
            print(f"Error: File {input_path} not found.")
            return

        with open(input_path, 'rb') as f:
            # 1. Read metadata header first
            frequency = pickle.load(f)
            # 2. Read the remaining compressed bitstream bytes
            compressed_bytes = f.read()

        # Rebuild tree mapping from metadata
        root = self._build_huffman_tree(frequency)
        self._make_codes(root)

        # Reconstruct bit stream string
        bit_string = ""
        for byte in compressed_bytes:
            bit_string += "{0:08b}".format(byte)

        # Remove byte padding using structural info embedded inside header bits
        padded_info = bit_string[:8]
        extra_padding = int(padded_info, 2)
        bit_string = bit_string[8 : len(bit_string) - extra_padding]

        # Decode bitstream into original byte arrays
        decompressed_bytes = bytearray()
        current_code = ""
        for bit in bit_string:
            current_code += bit
            if current_code in self.reverse_codes:
                decompressed_bytes.append(self.reverse_codes[current_code])
                current_code = ""

        with open(output_path, 'wb') as output_file:
            output_file.write(decompressed_bytes)
            
        print(f"Decompression successful! Saved to {output_path}")

# --- Example Usage ---
if __name__ == "__main__":
    zipper = FileZipper()
    
    # Create a dummy sample text file
    sample_text = b"Bumblebees love big bright blossoms. Bumblebees love big bright blossoms."
    with open("sample.txt", "wb") as f:
        f.write(sample_text)
        
    # Run compression cycle
    zipper.compress("sample.txt", "compressed.zip")
    zipper.decompress("compressed.zip", "restored.txt")
