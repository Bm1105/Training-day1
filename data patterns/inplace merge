import math

def next_gap(gap):
    if gap <= 1:
        return 0
    return (gap // 2) + (gap % 2)

def merge_in_place(arr):
    n = len(arr)
    gap = next_gap(n)

    while gap > 0:
        i = 0
        while i + gap < n:
            if arr[i] > arr[i + gap]:
                arr[i], arr[i + gap] = arr[i + gap], arr[i]
            i += 1
        gap = next_gap(gap)

arr = list(map(int, input().split()))

merge_in_place(arr)
print(*arr)
