#include <stdio.h>

double power(double x, unsigned int n, unsigned int *count) {
    double result = 1.0;

    while (n > 0) {
        if (n % 2 == 1) {
            result *= x;
            (*count)++;
        }

        x *= x;
        (*count)++;
        n /= 2;
    }

    return result;
}

int main() {
    double x;
    unsigned int n;
    unsigned int count = 0;

    printf("Enter base and exponent: ");
    scanf("%lf %u", &x, &n);

    double res = power(x, n, &count);

    printf("Result = %.6f\n", res);
    printf("Multiplications = %u\n", count);

    return 0;
}
